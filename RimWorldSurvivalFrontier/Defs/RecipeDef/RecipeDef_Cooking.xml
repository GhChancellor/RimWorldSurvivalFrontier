<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <!--    see: Defs/RecipeDefs/Recipes_Food.xml > Make_Pemmican -->

    <RecipeDef Name="RSF_TemplateRSF_Dried" Abstract="true">
        <!-- Mechanic CORE -->
        <requiredGiverWorkType>Cooking</requiredGiverWorkType>
        <allowMixingIngredients>true</allowMixingIngredients>
        <ingredientValueGetterClass>IngredientValueGetter_Nutrition</ingredientValueGetterClass>

        <workSpeedStat>CookSpeed</workSpeedStat> <!-- Work Speed Stat -->
        <workSkill>Cooking</workSkill> <!-- Work XP Skill -->

        <!-- Where you craft it -->
        <recipeUsers>
            <li>FueledStove</li>
            <li>ElectricStove</li>
            <li>RSF_ChemFuelStove</li>
            <li>Campfire</li>
        </recipeUsers>

        <displayPriority>1440</displayPriority>

        <!-- Effect Working & sound -->
        <soundWorking>Recipe_CookMeal</soundWorking>
        <effectWorking>Cook</effectWorking>

    </RecipeDef>

    <!--  ================= RSF_DriedMeatRecipe  ================= -->
    <RecipeDef ParentName="RSF_TemplateRSF_Dried">
        <!-- ID -->
        <defName>RSF_DriedMeatRecipe</defName>
        <label>RSF_DriedMeatRecipe.label</label>
        <description>RSF_DriedMeatRecipe.description</description>
        <jobString>RSF_DriedMeatRecipe.jobString</jobString>

        <!-- Mechanic CORE -->
        <workAmount>1000</workAmount>

        <!-- Recipe ingredients -->
        <ingredients>
            <li>
                <filter>
                    <categories>
                        <li>MeatRaw</li>
                    </categories>

                    <!-- DISALLOWED items -->
                    <disallowedThingDefs>
                        <li>RSF_DriedMeat</li>
                    </disallowedThingDefs>
                </filter>
                <count>0.33</count>
            </li>
        </ingredients>

        <!-- What CAN be selected -->
        <fixedIngredientFilter>
            <categories>
                <li>MeatRaw</li>
            </categories>

            <!-- DISALLOWED items -->
            <disallowedThingDefs>
                <li>RSF_DriedMeat</li>
            </disallowedThingDefs>

            <!-- DISALLOWED categories -->
            <disallowedCategories>
                <li>AnimalProductRaw</li>
            </disallowedCategories>
            <specialFiltersToDisallow>
                <li>AllowPlantFood</li>
            </specialFiltersToDisallow>
        </fixedIngredientFilter>

        <!-- Pre-selected by default -->
        <defaultIngredientFilter>
            <categories>
                <li>MeatRaw</li>
            </categories>

            <!-- DISALLOWED items -->
            <disallowedThingDefs>
                <li>RSF_DriedMeat</li>

                <!-- Anomaly DLC: exclude Meat_Twisted -->
                <li MayRequire="Ludeon.RimWorld.Anomaly">Meat_Twisted</li>
            </disallowedThingDefs>
        </defaultIngredientFilter>

        <!-- Output Products -->
        <products>
            <RSF_DriedMeat>11</RSF_DriedMeat>
        </products>

    </RecipeDef>

