<?xml version="1.0" encoding="utf-8"?>

<Defs>

    <!--    see: Defs/RecipeDefs/Recipes_Food.xml > Make_Pemmican -->
    <!--  ================= RSF_TemplatePreservedFood  ================= -->
    <RecipeDef Name="RSF_TemplatePreservedFood" Abstract="true">
        <!-- ID -->
        <label>RSF_Template Preserved Food</label>
        <description>Make pemmican, a preserved combination of meat and plant food. It doesn't taste amazing, but lasts
            a long time without refrigeration.</description>
        <jobString>Making pemmican.</jobString>

        <!-- Mechanic CORE -->
        <workAmount>700</workAmount>
        <workSpeedStat>CookSpeed</workSpeedStat>
        <requiredGiverWorkType>Cooking</requiredGiverWorkType>

        <!-- Ingredient stuff -->
        <allowMixingIngredients>true</allowMixingIngredients>
        <ingredientValueGetterClass>IngredientValueGetter_Nutrition</ingredientValueGetterClass>
        <workSkill>Cooking</workSkill>
        <displayPriority>1440</displayPriority>

        <!-- Where you craft it  -->
        <recipeUsers>
            <li>FueledStove</li>
            <li>ElectricStove</li>
            <li>RSF_ChemFuelStove</li>
            <li>Campfire</li>
        </recipeUsers>

        <!-- Pre-selected by default -->
        <defaultIngredientFilter>
            <!-- Disallowed Items -->
            <disallowedThingDefs>
                <!-- Anomaly DLC: exclude twisted meat -->
                <li MayRequire="Ludeon.RimWorld.Anomaly">Meat_Twisted</li>
            </disallowedThingDefs>
        </defaultIngredientFilter>

        <!-- Effect Working & sound -->
        <effectWorking>Cook</effectWorking>
        <soundWorking>Recipe_CookMeal</soundWorking>
    </RecipeDef>

    <!--  ================= RSF_DriedMeatRecipe  ================= -->
    <RecipeDef ParentName="RSF_TemplatePreservedFood">
        <defName>RSF_DriedMeatRecipe</defName>
        <label>RSF_DriedMeatRecipe.label</label>
        <jobString>RSF_DriedMeatRecipe.jobString</jobString>

        <!-- Mechanic CORE -->
        <workAmount>700</workAmount>

        <!-- Recipe ingredients -->
        <ingredients>
            <li>
                <filter>

                    <!-- Material categories: defines which items can be crafted from this material -->
                    <!-- "Woody" = furniture, structures, floors (same as wood/plasteel in vanilla) -->
                    <categories>
                        <li>MeatRaw</li>
                    </categories>
                </filter>
                <count>0.35</count>
            </li>
        </ingredients>

        <!-- What CAN be selected -->
        <fixedIngredientFilter>

            <!-- Allowed categories -->
            <!-- Material categories: defines which items can be crafted from this material -->
            <!-- "Woody" = furniture, structures, floors (same as wood/plasteel in vanilla) -->
            <categories>
                <li>MeatRaw</li>
            </categories>

            <!-- Disallowed categories -->
            <disallowedCategories>
                <li>AnimalProductRaw</li>
                <li>PlantFoodRaw</li>
            </disallowedCategories>
        </fixedIngredientFilter>

        <!-- Pre-selected by default -->
        <defaultIngredientFilter>

            <!-- Material categories: defines which items can be crafted from this material -->
            <!-- "Woody" = furniture, structures, floors (same as wood/plasteel in vanilla) -->
            <categories>
                <li>MeatRaw</li>
            </categories>
        </defaultIngredientFilter>

        <!-- Output Products -->
        <products>
            <RSF_DriedMeat>16</RSF_DriedMeat>
        </products>
    </RecipeDef>

