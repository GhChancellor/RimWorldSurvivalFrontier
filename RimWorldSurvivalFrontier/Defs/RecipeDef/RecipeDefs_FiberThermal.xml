<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <!--  ================= RSF_TemplateFiberRecipe  ================= -->
    <RecipeDef Name="RSF_TemplateFiberRecipe" Abstract="true">
        <!-- Mechanic CORE -->
        <workSpeedStat>GeneralLaborSpeed</workSpeedStat> <!-- Work Speed Stat -->
        <workSkill>Crafting</workSkill> <!-- Work XP Skill -->

        <!-- Preserves work progress if interrupted -->
        <unfinishedThingDef>UnfinishedComponent</unfinishedThingDef>

        <!-- Effect Working & sound -->
        <effectWorking>Cremate</effectWorking>
        <soundWorking>Recipe_Cremate</soundWorking>
    </RecipeDef>

    <!--  ================= RSF_PlasticFiberRecipe ================= -->
    <RecipeDef ParentName="RSF_TemplateFiberRecipe">
        <!-- RecipeDefs/Recipes_Production_Vanilla.xml > Make_ChemfuelFromWood -->
        <!-- ID -->
        <defName>RSF_PlasticFiberRecipe</defName>
        <label>RSF_PlasticFiberRecipe.label</label>
        <description>RSF_PlasticFiberRecipe.description</description>
        <jobString>RSF_PlasticFiberRecipe.jobString</jobString>

        <!-- Mechanic CORE -->
        <workAmount>600</workAmount>
        <researchPrerequisite>RSF_PlasticFiberResearch</researchPrerequisite> <!-- unlock this items
        See: EcoPlastic/Doc/Images/Research/Unlock_RSF_PlasticBasic.png -->

        <!-- Requirements -->
        <skillRequirements>
            <Crafting>5</Crafting>
        </skillRequirements>

        <!-- Where you craft it  -->
        <recipeUsers Inherit="False"> <!-- don't merge with parent recipe users  -->
            <li>BiofuelRefinery</li>
        </recipeUsers>

        <!-- Recipe ingredients -->
        <ingredients>
            <li>
                <filter>
                    <!-- thingDefs: defines which item can be crafted from this material -->
                    <thingDefs>
                        <li>Chemfuel</li>
                    </thingDefs>
                </filter>
                <count>35</count>
            </li>
        </ingredients>

        <!-- Effect Working & sound -->
        <products>
            <RSF_PlasticFiber>28</RSF_PlasticFiber>
        </products>

    </RecipeDef>

