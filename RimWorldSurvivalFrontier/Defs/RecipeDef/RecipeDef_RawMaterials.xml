    <!-- ================= RSF_PlasticBioSteelRecipe =================-->
    <RecipeDef ParentName="RSF_TemplateRawMaterialRecipe">
        <!-- RecipeDefs/Recipes_Production_Vanilla.xml > Make_ChemfuelFromWood -->
        <!-- ID -->
        <defName>RSF_PlasticBioSteelRecipe</defName>
        <label>RSF_PlasticBioSteelRecipe.label</label>
        <description>RSF_PlasticBioSteelRecipe.description</description>
        <jobString>RSF_PlasticBioSteelRecipe.jobString</jobString>

        <!-- Mechanic CORE -->
        <workAmount>5000</workAmount>
        <researchPrerequisite>RSF_PlasticBioSteelResearch</researchPrerequisite> <!-- unlock this
        items See: EcoPlastic/Doc/Images/Research/Unlock_RSF_PlasticBasic.png -->

        <!-- Requirements -->
        <skillRequirements>
            <Crafting>8</Crafting>
        </skillRequirements>

        <!-- Where you craft it  -->
        <recipeUsers Inherit="False"> <!-- don't merge with parent recipe users  -->
            <li>FabricationBench</li> <!-- Fabrication bench -->
        </recipeUsers>

        <!-- Recipe ingredients -->
        <ingredients>
            <li>
                <filter>
                    <!-- thingDefs: defines which item can be crafted from this material -->
                    <thingDefs>
                        <li>Steel</li>
                    </thingDefs>
                </filter>
                <count>20</count>
            </li>
            <li>
                <filter>
                    <!-- thingDefs: defines which item can be crafted from this material -->
                    <thingDefs>
                        <li>RSF_PlasticIndustrial</li>
                    </thingDefs>
                </filter>
                <count>18</count>
            </li>
            <li>
                <filter>
                    <!-- thingDefs: defines which item can be crafted from this material -->
                    <thingDefs>
                        <li>Chemfuel</li>
                    </thingDefs>
                </filter>
                <count>4</count>
            </li>
        </ingredients>

        <!-- What CAN be selected -->
        <fixedIngredientFilter>
            <!-- Allowed items -->
            <thingDefs>
                <li>Steel</li>
                <li>RSF_PlasticIndustrial</li>
                <li>Chemfuel</li>
            </thingDefs>
        </fixedIngredientFilter>

        <!-- Output material-->
        <products>
            <RSF_PlasticBioSteel>30</RSF_PlasticBioSteel>
        </products>
    </RecipeDef>

