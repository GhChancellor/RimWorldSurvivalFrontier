<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <!--  ================= RSF_TemplateRawMaterialRecipe ================= -->
    <RecipeDef Name="RSF_TemplateRawMaterialRecipe" Abstract="true">
        <!-- Mechanic CORE -->
        <workSpeedStat>GeneralLaborSpeed</workSpeedStat> <!-- Work Speed Stat -->
        <workSkill>Crafting</workSkill> <!-- Work XP Skill -->

        <!-- Preserves work progress if interrupted -->
        <unfinishedThingDef>UnfinishedComponent</unfinishedThingDef>

        <!-- Where you craft it  -->
        <recipeUsers>
            <li>BiofuelRefinery</li>
        </recipeUsers>

        <!-- Effect Working & sound -->
        <effectWorking>Cremate</effectWorking>
        <soundWorking>Recipe_Cremate</soundWorking>
    </RecipeDef>

    <!--  ================= RSF_PlasticBasicRecipe ================= -->
    <RecipeDef ParentName="RSF_TemplateRawMaterialRecipe">
        <!-- RecipeDefs/Recipes_Production_Vanilla.xml > Make_ChemfuelFromWood -->
        <!-- ID -->
        <defName>RSF_PlasticBasicRecipe</defName>
        <label>RSF_PlasticBasicRecipe.label</label>
        <description>RSF_PlasticBasicRecipe.description</description>
        <jobString>RSF_PlasticBasicRecipe.jobString</jobString>

        <!-- Mechanic CORE -->
        <workAmount>800</workAmount>
        <researchPrerequisite>RSF_PlasticBasicResearch</researchPrerequisite> <!-- unlock this items
        See: EcoPlastic/Doc/Images/Research/Unlock_RSF_PlasticBasic.png -->

        <!-- Recipe ingredients -->
        <ingredients>
            <li>
                <filter>
                    <!-- thingDefs: defines which items can be crafted from this material -->
                    <thingDefs>
                        <li>Chemfuel</li>
                    </thingDefs>
                </filter>
                <count>40</count>
            </li>
        </ingredients>

        <!-- Output material-->
        <products>
            <RSF_PlasticBasic>25</RSF_PlasticBasic>
        </products>
    </RecipeDef>

