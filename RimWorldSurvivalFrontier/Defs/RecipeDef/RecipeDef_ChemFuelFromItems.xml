<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!--  ================= RSF_TemplateChemFuel  ================= -->
    <RecipeDef Name="RSF_TemplateChemFuel" Abstract="true">

        <!-- Mechanic CORE -->
        <workSpeedStat>GeneralLaborSpeed</workSpeedStat> <!-- Work Speed Stat -->
        <workSkill>Crafting</workSkill> <!-- Work XP Skill -->

        <!-- Where you craft it  -->
        <recipeUsers>
            <li>BiofuelRefinery</li>
        </recipeUsers>

        <!-- Effect Working & sound -->
        <effectWorking>Cremate</effectWorking>
        <soundWorking>Recipe_Cremate</soundWorking>
    </RecipeDef>

    <!--  ================= RSF_ChemfuelFromHumanCorpse  ================= -->
    <RecipeDef ParentName="RSF_TemplateChemFuel">
        <!-- ID -->
        <defName>RSF_ChemfuelFromHumanCorpse</defName>
        <label>RSF_ChemfuelFromHumanCorpse.label</label>
        <description>RSF_ChemfuelFromHumanCorpse.description</description>
        <jobString>RSF_ChemfuelFromHumanCorpse.jobString</jobString>

        <!-- Mechanic CORE -->
        <workAmount>6000</workAmount>

        <!-- Recipe ingredients -->
        <ingredients>
            <li>
                <filter>

                    <!-- Material categories: defines which items can be crafted from this material -->
                    <!-- "Woody" = furniture, structures, floors (same as wood/plasteel in vanilla) -->
                    <categories>
                        <li>CorpsesHumanlike</li>
                    </categories>
                </filter>
                <count>1</count>
            </li>
        </ingredients>

        <!-- What CAN be selected -->
        <fixedIngredientFilter>

            <!-- Allowed categories -->
            <!-- Material categories: defines which items can be crafted from this material -->
            <!-- "Woody" = furniture, structures, floors (same as wood/plasteel in vanilla) -->
            <categories>
                <li>CorpsesHumanlike</li>
            </categories>
        </fixedIngredientFilter>

        <!-- Output Products -->
        <products>
            <Chemfuel>90</Chemfuel>
        </products>
    </RecipeDef>

</Defs>