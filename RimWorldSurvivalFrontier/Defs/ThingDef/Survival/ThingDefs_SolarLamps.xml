<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!--  ================= TemplateSunLamp ================= -->
    <ThingDef Name="TemplateSunLamp" ParentName="LampBase" Abstract="true">
        <!-- ID -->
        <label>Template Sun Lamp</label>
        <description>An industrial lamp which lights an area brightly enough to grow crops, but consumes a huge amount
            of power. Automatically turns itself off at night.
        </description>

        <!-- Icons & colors -->
        <graphicData>
            <texPath>Things/Building/Production/LampSun</texPath>
            <shadowData>
                <volume>(0.3, 0.6, 0.3)</volume>
                <offset>(0,0,-0.1)</offset>
            </shadowData>
        </graphicData>

        <thingClass>Building_SunLamp</thingClass>

        <!-- Ui Order: controls the order of items in the inventory -->
        <uiOrder>2995</uiOrder>

        <!-- Wind block -->
        <blockWind>true</blockWind>

        <!-- Tick rate: controls update frequency (Rare = ~4sec intervals) -->
        <tickerType>Rare</tickerType>

        <!-- Base stats: Affects ONLY the item itself (inventory/ground), NOT buildings -->
        <statBases>
            <WorkToBuild>330</WorkToBuild>
            <Mass>4.5</Mass>  <!-- Item weight (kg) -->
        </statBases>

        <!-- Specifies exact materials and quantities -->
        <costList>
            <Steel>40</Steel>
        </costList>

        <!-- Determined by trial and error
        This value isn't perfect because these radii use different algorithms
        but it matches in this case-->

        <!-- Special display radius for light effects on plants -->
        <specialDisplayRadius>5.8</specialDisplayRadius>
    </ThingDef>

    <!--  ================= RSF_SunWallLamp ================= -->
    <ThingDef ParentName="TemplateSunLamp">
        <!-- ID -->
        <defName>RSF_SunWallLamp</defName>
        <label>SunWallLamp.label</label>
        <description>SunWallLamp.description</description>

        <!-- Mechanic CORE -->
        <rotatable>true</rotatable>

        <!-- Icons & colors -->
        <graphicData>
            <texPath>Things/Building/Furniture/WallLamp/WallLamp</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawOffsetNorth>(0,0,0.9)</drawOffsetNorth>
            <drawOffsetSouth>(0,0,-0.9)</drawOffsetSouth>
            <drawOffsetWest>(-0.9,0,0)</drawOffsetWest>
            <drawOffsetEast>(0.9,0,0)</drawOffsetEast>
            <damageData>
                <enabled>false</enabled>
            </damageData>
        </graphicData>

        <!-- Icons -->
        <uiIconPath>Things/Building/Furniture/WallLamp/WallLamp_MenuIcon</uiIconPath>

        <altitudeLayer>BuildingOnTop</altitudeLayer>
        <terrainAffordanceNeeded IsNull="True"/>
        <building>
            <isEdifice>false</isEdifice>
            <isAttachment>true</isAttachment>
        </building>
        <placeWorkers>
            <li>Placeworker_AttachedToWall</li>
        </placeWorkers>

        <!-- Base stats: Affects ONLY the item itself (inventory/ground), NOT buildings -->
        <statBases>
            <WorkToBuild>132</WorkToBuild>
            <Mass>1.8</Mass>  <!-- Item weight (kg) -->
        </statBases>

        <!-- Specifies exact materials and quantities -->
        <costList>
            <Steel>16</Steel>
        </costList>

        <!-- Ui Order: controls the order of items in the inventory -->
        <uiOrder>2999</uiOrder>

        <!-- Components: behavior modules -->
        <comps>
            <li Class="CompProperties_Glower">
                <overlightRadius>4.5</overlightRadius> <!-- I don't understand how to work -->
                <glowRadius>6.5</glowRadius> <!-- I don't understand how to work -->
                <glowColor>(370,370,370,0)</glowColor>
            </li>
            <li Class="CompProperties_Power">
                <compClass>CompPowerTrader</compClass>
                <shortCircuitInRain>true</shortCircuitInRain>
                <basePowerConsumption>1160</basePowerConsumption>
            </li>
            <li Class="CompProperties_HeatPusher">
                <compClass>CompHeatPusherPowered</compClass>
                <heatPerSecond>1.9</heatPerSecond>
            </li>
            <li Class="CompProperties_Schedule">
                <!-- Match plant growing times -->
                <startTime>0.25</startTime>
                <endTime>0.8</endTime>
                <offMessage>Off for plant resting period</offMessage>
            </li>
        </comps>

        <!-- Special display radius for light effects on plants -->
        <specialDisplayRadius>3.9</specialDisplayRadius>

    </ThingDef>

