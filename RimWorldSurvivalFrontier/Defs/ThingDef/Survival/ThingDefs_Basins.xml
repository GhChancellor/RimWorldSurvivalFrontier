<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!--  ================= TemplateBasim ================= -->
    <ThingDef Name="TemplateBasin" ParentName="BuildingBase" Abstract="true">
        <!-- ID -->
        <label>Template</label>
        <description>A simple Template.</description>

        <noRightClickDraftAttack>true</noRightClickDraftAttack>
        <thingClass>Building_PlantGrower</thingClass>

        <!-- Icons & colors -->
        <graphicData>
            <texPath>Things/Building/Production/HydroponicsBasin</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <color>(150, 111, 51)</color>
            <drawSize>(1,4)</drawSize>
            <damageData>
                <cornerTL>Damage/Corner</cornerTL>
                <cornerTR>Damage/Corner</cornerTR>
                <cornerBL>Damage/Corner</cornerBL>
                <cornerBR>Damage/Corner</cornerBR>
            </damageData>
        </graphicData>

        <castEdgeShadows>true</castEdgeShadows>
        <altitudeLayer>LowPlant</altitudeLayer>
        <defaultPlacingRot>East</defaultPlacingRot>
        <passability>PassThroughOnly</passability>
        <pathCost>30</pathCost>

        <fillPercent>0.30</fillPercent>
        <canOverlapZones>false</canOverlapZones>

        <!-- construction Skill Prerequisite -->
        <constructionSkillPrerequisite>4</constructionSkillPrerequisite>

        <!-- Base stats: Affects ONLY the item itself (inventory/ground), NOT buildings -->
        <statBases>
            <!-- HP when item is on ground/inventory -->
            <WorkToBuild>1500</WorkToBuild>
            <MaxHitPoints>120</MaxHitPoints>
            <Flammability>0.5</Flammability>
            <Cleanliness>-3</Cleanliness>
            <Mass>5</Mass>  <!-- Item weight (kg), it's necessary for MinifiedThing -->
        </statBases>

        <!-- Items size -->
        <size>(1,4)</size>

        <!-- Basin fertility -->
        <fertility>1.2</fertility>

        <!-- Ui Order: controls the order of items in the inventory -->
        <uiOrder>2995</uiOrder>

        <building>
            <defaultPlantToGrow>Plant_Rice</defaultPlantToGrow>
            <sowTag>CustomSowTagPlants</sowTag>
            <buildingTags>
                <li>Production</li> <!-- Menù production -->
            </buildingTags>
        </building>

        <!-- Tick rate: controls update frequency (Rare = ~4sec intervals) -->
        <tickerType>Rare</tickerType>

        <!-- These two tags work together - you cannot have one without the other -->
        <!-- If you define stuffCategories, you MUST also define costStuffCount -->

        <!-- stuffCategories defines WHICH material types can be used -->
        <stuffCategories>
            <li>Woody</li> <!-- materials used to build this item -->
            <li>Stony</li>
        </stuffCategories>

        <!-- Defines WHICH and HOW MUCH of that material is required -->
        <costStuffCount>50</costStuffCount>

        <!-- Specifies exact materials and quantities -->
        <costList>
            <Steel>3</Steel>
        </costList>

        <terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>

        <!--Which menu appear Production/Furniture/Recreation/Security -->
        <designationCategory>Production</designationCategory>

        <neverMultiSelect>false</neverMultiSelect>

        <!-- ********** MinifiedThing ************** -->

        <minifiedDef>MinifiedThing</minifiedDef>
        <overrideMinifiedRot>North</overrideMinifiedRot>
        <minifiedDrawOffset>(0, 0, 0.2)</minifiedDrawOffset>

        <thingCategories>
            <li>BuildingsFurniture</li> <!-- it's necessary for MinifiedThing -->
        </thingCategories>

        <!-- ************************************* -->
    </ThingDef>

