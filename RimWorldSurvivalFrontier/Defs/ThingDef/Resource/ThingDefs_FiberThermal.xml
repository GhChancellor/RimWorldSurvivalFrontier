<?xml version="1.0" encoding="utf-8"?>

<Defs>
    <!-- ================= RSF_PlasticFiber > ThingCategoryDef TradingGoods ================= -->
    <ThingDef ParentName="ResourceBase">
        <!--ThingDefs_Items/Items_Resource_Stuff.xml > Cloth-->
        <!-- ID -->
        <defName>RSF_PlasticFiber</defName>
        <label>RSF_PlasticFiber.label</label>
        <description>RSF_PlasticFiber.description</description>

        <!-- Icons & colors -->
        <graphicData>
            <texPath>Things/Item/Resource/Cloth</texPath>
            <graphicClass>Graphic_StackCount</graphicClass>
            <color>(240,248,240)</color> <!-- This is the color of the icon that you can see in the inventory! -->
            <!-- see: EcoPlastic/Doc/Images/ThingDef/IconColor.png-->
        </graphicData>

        <!-- Base stats: Affects ONLY the item itself (inventory/ground), NOT buildings -->
        <statBases>
            <StuffPower_Armor_Sharp>0.36</StuffPower_Armor_Sharp>   <!-- Protection vs cutting/stabbing -->
            <StuffPower_Armor_Blunt>0</StuffPower_Armor_Blunt>      <!-- Protection vs blunt impact -->
            <StuffPower_Armor_Heat>0.18</StuffPower_Armor_Heat>     <!-- Protection vs heat/fire -->
            <StuffPower_Insulation_Cold>18</StuffPower_Insulation_Cold> <!-- insulation cold -->
            <StuffPower_Insulation_Heat>18</StuffPower_Insulation_Heat> <!-- insulation heat -->

            <!-- HP when item is on ground/inventory -->
            <MaxHitPoints>80</MaxHitPoints> <!-- max HP -->
            <MarketValue>1.5</MarketValue> <!-- market value -->
            <Mass>0.026</Mass>  <!-- Item weight (kg) -->
            <Flammability>1.2</Flammability>
            <DeteriorationRate>4</DeteriorationRate> <!-- resistance to deterioration -->
        </statBases>

        <burnableByRecipe>true</burnableByRecipe>
        <healthAffectsPrice>false</healthAffectsPrice>
        <minRewardCount>30</minRewardCount>

        <!-- It has effects on constructed items -->
        <stuffProps>
            <statFactors>
                <Flammability>1.2</Flammability>
                <Beauty>1</Beauty>
            </statFactors>

            <!-- Material categories: defines which items can be crafted from this material -->
            <!-- "Woody" = furniture, structures, floors (same as wood/plasteel in vanilla) -->
            <categories>
                <li>Fabric</li>
            </categories>
            <color>(240,248,240)</color> <!-- This is the color of the icon that you can see in the menu and ingame! -->
            <!-- see: EcoPlastic/Doc/Images/ThingDef/IconcolorMenuAndGame.png-->
            <commonality>1.4</commonality>
            <allowColorGenerators>true</allowColorGenerators>
            <canSuggestUseDefaultStuff>false</canSuggestUseDefaultStuff>
        </stuffProps>

        <thingCategories>
            <li>Textiles</li>
            <li>TradingGoods</li> <!-- Custom category for traders see: PatchTraders.xml > categoryDef-->
        </thingCategories>

        <!-- Components: behavior modules -->
        <comps>
            <li>
                <compClass>CompColorable</compClass>
            </li>
        </comps>

        <colorGeneratorInTraderStock Class="ColorGenerator_Options">
            <options>
                <li>
                    <weight>5</weight>
                    <only>(0.33,0.33,0.33,1)</only>
                </li>
                <li>
                    <weight>10</weight>
                    <min>(0.3,0.3,0.3,1)</min>
                    <max>(0.9,0.9,0.9,1)</max>
                </li>
                <li>
                    <weight>5</weight>
                    <only>(0.9,0.9,0.9,1)</only>
                </li>
            </options>
        </colorGeneratorInTraderStock>

        <allowedArchonexusCount>80</allowedArchonexusCount>
    </ThingDef>

    <!-- ================= RSF_EcoLeather > ThingCategoryDef TradingGoods ================= -->
    <ThingDef ParentName="LeatherBase">
        <!-- ID -->
        <defName>RSF_EcoLeather</defName>
        <label>RSF_EcoLeather.label</label>
        <description>RSF_EcoLeather.description</description>

        <!-- Icons & colors -->
        <graphicData>
            <texPath>Things/Item/Resource/Leather</texPath>
            <color>(85,107,47)</color> <!-- This is the color of the icon that you can see in the inventory! -->
            <!-- see: EcoPlastic/Doc/Images/ThingDef/IconColor.png-->
        </graphicData>

        <!-- Base stats: Affects ONLY the item itself (inventory/ground), NOT buildings -->
        <statBases>
            <MarketValue>2.5</MarketValue> <!-- Market value: Higher than wood, but lower than -->
            <Mass>0.025</Mass>  <!-- Item weight (kg) -->
            <DeteriorationRate>1.5</DeteriorationRate> <!-- resistance to deterioration -->
            <StuffPower_Insulation_Cold>18</StuffPower_Insulation_Cold> <!-- Insulation Cold -->
            <StuffPower_Insulation_Heat>18</StuffPower_Insulation_Heat> <!-- Insulation Heat -->
        </statBases>

        <!-- It has effects on constructed items -->
        <stuffProps>
            <!--            <stuffAdjective>plastic leather</stuffAdjective>-->

            <!-- Material categories: defines which items can be crafted from this material -->
            <!-- "Woody" = furniture, structures, floors (same as wood/plasteel in vanilla) -->
            <categories>
                <li>Leathery</li>
            </categories>
            <commonality>0.02</commonality>
        </stuffProps>

        <thingCategories>
            <li>TradingGoods</li> <!-- Custom category for traders see: PatchTraders.xml > categoryDef-->
        </thingCategories>
    </ThingDef>

